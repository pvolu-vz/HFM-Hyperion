# Oracle Hyperion HFM — Veza OAA Integration
# Copy this file to .env and fill in your values

# HFM Data Source Files
# Paths can be local or on an SMB/CIFS mounted share (e.g. /mnt/hfm-share/)
HFM_SEC_FILE=/path/to/SW_Security.sec
HFM_GROUPS_CSV=/path/to/Groups.csv

# Veza Configuration
VEZA_URL=your-company.vezacloud.com
VEZA_API_KEY=your_veza_api_key_here

# OAA Provider Settings (optional overrides)
# PROVIDER_NAME=Oracle Hyperion HFM
# DATASOURCE_NAME=HFM Security
